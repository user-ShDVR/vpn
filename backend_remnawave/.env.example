# Core
DATABASE_URL=postgres://vpn:vpn@localhost:5432/vpn?sslmode=disable
JWT_SECRET=change-me-in-prod
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
WEB_STATIC_PATH=./web/static
MIGRATIONS_PATH=./migrations

# Cookies (set true behind HTTPS in prod)
COOKIE_SECURE=false

# CORS (concrete origin in prod, e.g. https://cabinet.svyaz-ok.example)
CORS_ORIGINS=*

REMNAWAVE_BASE_URL=https://panel.svyazok.ru
REMNAWAVE_TOKEN=

# Platega merchant credentials.
# baseURL defaults to https://app.platega.io when empty.
PLATEGA_BASE_URL=
PLATEGA_MERCHANT_ID=
PLATEGA_SECRET=
# Numeric paymentMethod ID — see Platega merchant dashboard. 1 = cards.
PLATEGA_PAYMENT_METHOD=1
# Optional: override URLs Platega redirects the user back to. When empty,
# the cabinet uses PUBLIC_BASE_URL/payment/platega/{return,fail}.
PLATEGA_RETURN_URL=
PLATEGA_FAIL_URL=

# SMTP — leave SMTP_HOST empty in dev to skip emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@svyaz-ok.example
SMTP_TLS_MODE=starttls

# Support page links
SUPPORT_TG_URL=https://t.me/svyaz_ok_support
SUPPORT_EMAIL=postmaster@svyazok.ru
SUPPORT_FAQ_URL=

# Email gating (set true to require verified email before plan purchase)
REQUIRE_EMAIL_VERIFY=false

# Caddy (prod profile)
DOMAIN=svyazok.ru
ACME_EMAIL=postmaster@svyazok.ru

# Yandex Metrika (empty disables)
YANDEX_METRIKA_ID=
