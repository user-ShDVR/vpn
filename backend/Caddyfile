# Caddy auto-TLS via Let's Encrypt. Set DOMAIN env in docker-compose.
# Caddy negotiates the cert on first request and renews automatically.

{$DOMAIN} {
    # Redirect to HTTPS happens automatically when DOMAIN includes no scheme.
    encode zstd gzip

    # Security headers — CSP intentionally permissive for inline htmx attrs.
    header {
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "DENY"
        Referrer-Policy           "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        Permissions-Policy        "camera=(), microphone=(), geolocation=()"
        -Server
    }

    # Static assets directly from the filesystem if mounted, else proxy.
    @static path /static/*
    handle @static {
        reverse_proxy api:8080
    }

    # Subscription endpoint — high traffic, long cache OK on edge but sub
    # content varies per token, so just pass through.
    @sub path /sub/*
    handle @sub {
        reverse_proxy api:8080
    }

    # Everything else
    handle {
        reverse_proxy api:8080 {
            header_up X-Real-IP {remote_host}
        }
    }
}
